# ========================================
# BB Maintenance Backend - Environment
# ========================================

# Application
NODE_ENV=production
PORT=3000
APP_NAME=bbonemx-maintenance

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=bbonemx_db
DB_SYNCHRONIZE=false
# `synchronize` solo se permite en desarrollo local; en despliegues usa migraciones versionadas.
DB_LOGGING=false

# JWT Authentication
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=7d
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
COOKIE_SECURE=true
COOKIE_DOMAIN=.yourdomain.com

# Auth Rate Limiting
AUTH_MAX_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# GraphQL
GRAPHQL_PLAYGROUND=false
GRAPHQL_INTROSPECTION=false
GRAPHQL_DEBUG=false

# CORS
CORS_ORIGIN=https://yourdomain.com

# ========================================
# Scheduler / Cron Jobs
# ========================================
SCHEDULER_ENABLED=true

# Tareas preventivas (cada hora)
CRON_PREVENTIVE_TASKS_ENABLED=true
CRON_PREVENTIVE_TASKS=0 * * * *

# Recordatorios (diario 8:00)
CRON_REMINDERS_ENABLED=false
CRON_REMINDERS=0 8 * * *

# Limpieza de registros antiguos (diario 3:00 AM)
CRON_CLEANUP_ENABLED=false
CRON_CLEANUP=0 3 * * *
CRON_CLEANUP_RETENTION_DAYS=90

# Cumpleaños de técnicos (correo semanal a administradores; lunes 8:00 Ciudad de México)
CRON_TECHNICIAN_BIRTHDAYS_ENABLED=false
CRON_TECHNICIAN_BIRTHDAYS=0 8 * * 1
CRON_TECHNICIAN_BIRTHDAYS_TZ=America/Mexico_City

# ========================================
# Firebase Cloud Messaging (FCM)
# ========================================
# Elige UNA de las 3 opciones:

# Opción 1: Ruta al archivo JSON de service account (recomendado para local)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Opción 2: JSON inline (recomendado para Docker/CI/CD)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Opción 3: Variables individuales
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ========================================
# Email (SMTP / Nodemailer)
# ========================================
EMAIL_ENABLE=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_DEFAULT_FROM_NAME=Bumble Bee Maintenance
EMAIL_FROM_ADDRESS=no-reply@bumblebeefoods.com

# ========================================
# Redis (opcional, requerido para suscripciones multi-instancia)
# ========================================
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ========================================
# Seed (solo para configuración inicial, no requerido en runtime)
# ========================================
ADMIN_SEED_PASSWORD=change_me
