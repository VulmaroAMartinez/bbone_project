# ========================================
# BB Maintenance Backend - Environment
# ========================================

# Application
NODE_ENV=development
PORT=3000
APP_NAME=bbonemx-maintenance

# Database - PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=bbonemx_db
DB_SYNCHRONIZE=false
# `synchronize` solo se permite en desarrollo local; en despliegues usa migraciones versionadas.
DB_LOGGING=true

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# GraphQL
GRAPHQL_PLAYGROUND=true
GRAPHQL_INTROSPECTION=true
GRAPHQL_DEBUG=true

# Scheduler / Cron Jobs
SCHEDULER_ENABLED=true
CRON_PREVENTIVE_TASKS_ENABLED=true
CRON_PREVENTIVE_TASKS=0 * * * *
CRON_REMINDERS_ENABLED=false
CRON_REMINDERS=0 8 * * *

# ========================================
# Firebase Cloud Messaging (FCM)
# ========================================
# Elige UNA de las 3 opciones:

# Opción 1: Ruta al archivo JSON de service account (recomendado para local)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Opción 2: JSON inline (recomendado para Docker/CI/CD)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Opción 3: Variables individuales
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ========================================
# Email (SMTP / Nodemailer)
# ========================================
EMAIL_ENABLE=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_DEFAULT_FROM_NAME=Bumble Bee Maintenance
EMAIL_FROM_ADDRESS=no-reply@bumblebeefoods.com

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3001
