# ========================================
# BB Maintenance Frontend - Environment
# ========================================

# GraphQL Backend Endpoint
# Obligatoria en producción. Si falta, la app mostrará error de configuración inválida.
# Solo en desarrollo local (import.meta.env.DEV) se usa fallback automático a http://localhost:3000.
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# ========================================
# Firebase Cloud Messaging
# ========================================
# Obtener de: Firebase Console > Project Settings > General > Your apps > Web app

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# VAPID Key
# Obtener de: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates > Key pair
VITE_FIREBASE_VAPID_KEY=BHxxx...your_vapid_key_here
